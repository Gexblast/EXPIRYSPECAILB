# Render dashboard → Environment mein yeh 4 vars daalo
# (values apne Angel One SmartAPI account se — purane backend wale hi chalenge,
#  Angel One ek hi API key se multiple sessions allow karta hai)
ANGEL_API_KEY=your_api_key_here
ANGEL_CLIENT_ID=your_client_code_here
ANGEL_PIN=your_pin_here
ANGEL_TOTP_SECRET=your_totp_secret_here
